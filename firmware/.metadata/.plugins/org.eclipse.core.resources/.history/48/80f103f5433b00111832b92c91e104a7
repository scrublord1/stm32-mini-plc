//   OUT  Q0   ; Write to Motor output
//   END
static const uint8_t motor_start_stop_program[] = {
    OP_LD,   0x00,
    OP_OR,   0x10,
    OP_ANDN, 0x01,
    OP_OUT,  0x10,
    OP_END
};

#define MOTOR_PROGRAM_LEN  (sizeof(motor_start_stop_program))
