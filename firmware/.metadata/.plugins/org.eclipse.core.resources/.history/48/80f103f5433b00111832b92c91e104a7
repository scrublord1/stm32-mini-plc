// COUNTER DEMO: Motor turns ON after 5 presses of Start.
// Stop resets the counter.
//
//   LD  I0      ; Start input
//   CTU C0, 5   ; Count up, preset 5
//   LDC C0      ; Load counter output
//   OUT Q0      ; Motor
//   LD  I1      ; Stop input
//   RST C0      ; Reset counter
//   END
static const uint8_t counter_demo_program[] = {
    OP_LD,  0x00,
    OP_CTU, 0x30, 0x05, 0x00,   // C0, preset = 5
    OP_LDC, 0x30,
    OP_OUT, 0x10,
    OP_LD,  0x01,
    OP_RST, 0x30,
    OP_END
};

#define COUNTER_DEMO_PROGRAM_LEN (sizeof(counter_demo_program))
